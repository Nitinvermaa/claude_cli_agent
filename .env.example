# Copy to your project root as .env (do not commit .env).
# cagent loads these when you pass --cwd pointing at that directory.
#
# DEFAULT: backend "independent" uses ANTHROPIC_API_KEY below.
# Copilot backends are optional — uncomment GITHUB_TOKEN only if you use them.

# GitHub PAT for Copilot backends (copilot_sdk, langchain_copilot) — optional
# GITHUB_TOKEN=ghp_your_github_pat_here
# GH_TOKEN=ghp_your_github_pat_here
# COPILOT_GITHUB_TOKEN=ghp_your_github_pat_here
# CAGENT_COPILOT_MODEL=gpt-4.1

# Anthropic API key (any one of these names works)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
# CLAUDE_API_KEY=sk-ant-api03-your-key-here
# CAGENT_ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Model (optional)
ANTHROPIC_MODEL=claude-sonnet-4-6
# CLAUDE_MODEL=claude-sonnet-4-6
# CAGENT_MODEL=claude-sonnet-4-6

# Claude Code backend: raise max output tokens (default 32000)
# CLAUDE_CODE_MAX_OUTPUT_TOKENS=64000

# Independent backend tool loop
# CAGENT_INDEPENDENT_MAX_TOOL_ROUNDS=128
# CAGENT_INDEPENDENT_MAX_TOKENS=16384

# Graphify subprocess timeouts (seconds)
# CAGENT_GRAPHIFY_QUERY_TIMEOUT=8
# CAGENT_GRAPHIFY_UPDATE_TIMEOUT=30
